# Backend URL for development
# By default, uses window.location.origin (works in production where app is served by FastAPI)
# For development with separate Vite frontend and FastAPI backend, set this to the backend URL
# Example for local development: VITE_BACKEND_URL=http://127.0.0.1:7432
# VITE_BACKEND_URL=http://127.0.0.1:7432
