# =============================================================================
# .env.example — AI Tool Configuration for Roblox Studio Agency
# Copy this file to .env and fill in your values. Never commit .env.
# =============================================================================

# ─── GitHub token (required by the system) ───────────────────────────────────
GITHUB_TOKEN=your_github_token_here

# ─── Primary AI tool (used for all agents unless overridden) ─────────────────
# Supported values: claude | codex | gemini | opencode
PRIMARY_AI_TOOL=claude

# ─── Secondary fallback (used if primary exits non-zero) ─────────────────────
# Leave blank to disable. Must differ from primary.
SECONDARY_AI_TOOL=

# ─── Tertiary fallback (used if secondary exits non-zero) ────────────────────
# Leave blank to disable. Must differ from primary and secondary.
TERTIARY_AI_TOOL=

# ─── Per-tool model selection ─────────────────────────────────────────────────
# Leave blank to use each tool's built-in default model.
# Claude models: claude-opus-4-7, claude-sonnet-4-6, claude-haiku-4-5-20251001
CLAUDE_MODEL=
# Codex models: o4-mini, codex-mini-latest, gpt-4.1
CODEX_MODEL=
# Gemini models: gemini-2.5-pro, gemini-2.5-flash
GEMINI_MODEL=
# OpenCode: use provider/model format, e.g. anthropic/claude-sonnet-4-6
OPENCODE_MODEL=

# ─── Per-agent tool overrides ─────────────────────────────────────────────────
# Override the primary tool for a specific agent role.
# Leave blank to inherit PRIMARY_AI_TOOL.
#
# Example: use Gemini for cheaper read-only analysis roles,
#          keep Claude for Builder which writes Luau game code.
#
#   AGENT_TOOL_PLANNER=gemini
#   AGENT_TOOL_BUILDER=claude
#   AGENT_TOOL_MARKET_RESEARCHER=gemini
AGENT_TOOL_ARCHITECT=
AGENT_TOOL_PLANNER=
AGENT_TOOL_BUILDER=
AGENT_TOOL_REPORTER=
AGENT_TOOL_MARKET_RESEARCHER=
# Worker-builder and live-edit-builder are separate from builder so each
# operational context can use a different tool independently.
AGENT_TOOL_WORKER_BUILDER=
AGENT_TOOL_LIVE_EDIT_BUILDER=

# ─── Auth tokens for non-Claude tools ─────────────────────────────────────────
# Only needed if you use those tools as primary/secondary/tertiary.
OPENAI_API_KEY=
GEMINI_API_KEY=
# OpenCode uses whichever backend key is present (OPENAI_API_KEY or ANTHROPIC_API_KEY).
ANTHROPIC_API_KEY=
